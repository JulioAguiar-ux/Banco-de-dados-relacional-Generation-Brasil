--  Produtos com valor > 50
SELECT * FROM tb_produtos
WHERE preco > 50.00;

--  Produtos com valor entre 5 e 60
SELECT * FROM tb_produtos
WHERE preco BETWEEN 5.00 AND 60.00;

-- Produtos com letra C no nome
SELECT * FROM tb_produtos
WHERE nome LIKE "%C%";

-- produto + categoria
SELECT 
    p.nome,
    p.preco,
    p.estoque,
    c.nome_categoria
FROM tb_produtos p
INNER JOIN tb_categorias c
ON p.categoria_id = c.id;


