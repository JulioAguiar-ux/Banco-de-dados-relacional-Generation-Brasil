-- personagem + classe
SELECT 
    p.nome,
    p.poder_ataque,
    p.poder_defesa,
    p.nivel,
    c.nome_classe
FROM tb_personagens p
INNER JOIN tb_classes c
ON p.classe_id = c.id;


SELECT 
    p.nome,
    p.poder_ataque,
    p.poder_defesa,
    p.nivel,
    c.nome_classe
FROM tb_personagens p
INNER JOIN tb_classes c
ON p.classe_id = c.id
WHERE c.nome_classe = "Arqueiro";
